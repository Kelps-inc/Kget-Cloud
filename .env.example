# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kget_cloud

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Storage (local | r2 | s3)
STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=./uploads

# Cloudflare R2 (when STORAGE_PROVIDER=r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# AI chat / RAG
# Free MVP path: leave API keys empty. The app uses local deterministic
# embeddings and an extractive chat fallback.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
AI_BASE_URL=
AI_API_KEY=
AI_CHAT_MODEL=
AI_EMBEDDING_MODE=local

# Collection guardrails
COLLECTION_MAX_BYTES=52428800
COLLECTION_TIMEOUT_MS=60000

# AbacatePay (billing)
ABACATEPAY_API_KEY=
ABACATEPAY_WEBHOOK_SECRET=

# App
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
