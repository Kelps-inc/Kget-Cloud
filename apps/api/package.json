{
  "name": "@kget-cloud/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build && tsc-alias -p tsconfig.json",
    "start": "node dist/main",
    "postinstall": "prisma generate",
    "lint": "tsc --noEmit",
    "test": "bun test src/modules/knowledge/application/chunk-document.use-case.test.ts --pass-with-no-tests",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test src/modules/knowledge/application/chunk-document.use-case.test.ts --coverage --pass-with-no-tests",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "ts-node prisma/seed.ts",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.23",
    "@nestjs/core": "^11.1.23",
    "@nestjs/platform-express": "^11.1.23",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/websockets": "^11.1.23",
    "@nestjs/platform-socket.io": "^11.1.23",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/config": "^4.0.2",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/client": "^5.0.0",
    "bullmq": "^5.0.0",
    "ioredis": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.0",
    "passport-local": "^1.0.0",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.0",
    "express": "^5.2.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "zod": "^3.22.0",
    "multer": "^2.1.1",
    "openai": "^4.0.0",
    "pdf-parse": "^1.1.1",
    "cheerio": "^1.0.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.14",
    "@nestjs/testing": "^11.1.23",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "prisma": "^5.0.0",
    "ts-node": "^10.9.0",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.4.5"
  }
}
