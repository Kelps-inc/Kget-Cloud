generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  plan      String   @default("starter")
  createdAt DateTime @default(now())

  users        User[]
  agents       Agent[]
  sources      Source[]
  downloadJobs DownloadJob[]
  fileAssets   FileAsset[]
  jobLogs      JobLog[]
  chatSessions ChatSession[]

  @@map("organizations")
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String   @unique
  passwordHash   String
  role           String   @default("member")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("users")
}

model Agent {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  tokenHash      String    @unique
  status         String    @default("offline")
  lastSeenAt     DateTime?
  version        String?
  machineName    String?
  os             String?
  createdAt      DateTime  @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id])
  sources      Source[]
  downloadJobs DownloadJob[]

  @@map("agents")
}

model Source {
  id             String    @id @default(cuid())
  organizationId String
  agentId        String?
  type           String
  name           String
  configJson     Json      @default("{}")
  scheduleCron   String?
  enabled        Boolean   @default(true)
  createdAt      DateTime  @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id])
  agent        Agent?        @relation(fields: [agentId], references: [id])
  downloadJobs DownloadJob[]
  fileAssets   FileAsset[]

  @@map("sources")
}

model DownloadJob {
  id               String    @id @default(cuid())
  organizationId   String
  sourceId         String
  agentId          String?
  status           String    @default("queued")
  startedAt        DateTime?
  finishedAt       DateTime?
  errorMessage     String?
  bytesDownloaded  BigInt?
  durationMs       Int?
  createdAt        DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  source       Source       @relation(fields: [sourceId], references: [id])
  agent        Agent?       @relation(fields: [agentId], references: [id])
  fileAsset    FileAsset?
  logs         JobLog[]

  @@map("download_jobs")
}

model FileAsset {
  id                String    @id @default(cuid())
  organizationId    String
  sourceId          String?
  jobId             String?   @unique
  originalName      String
  storageKey        String    @unique
  mimeType          String
  sizeBytes         BigInt
  sha256            String
  status            String    @default("stored")
  extractedTextPath String?
  createdAt         DateTime  @default(now())

  organization   Organization    @relation(fields: [organizationId], references: [id])
  source         Source?         @relation(fields: [sourceId], references: [id])
  downloadJob    DownloadJob?    @relation(fields: [jobId], references: [id])
  documentChunks DocumentChunk[]

  @@map("file_assets")
}

model DocumentChunk {
  id             String                        @id @default(cuid())
  organizationId String
  fileId         String
  chunkIndex     Int
  content        String
  tokenCount     Int?
  embedding      Unsupported("vector(1536)")?
  metadataJson   Json                          @default("{}")

  fileAsset FileAsset @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@map("document_chunks")
}

model ChatSession {
  id             String   @id @default(cuid())
  organizationId String
  title          String?
  createdAt      DateTime @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id])
  messages     ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String
  sourceIds Json     @default("[]")
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

model JobLog {
  id             String   @id @default(cuid())
  organizationId String
  jobId          String
  level          String   @default("info")
  message        String
  metadataJson   Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  downloadJob  DownloadJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_logs")
}
