{
  "name": "kget-cloud",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:ci": "turbo run test -- --coverage",
    "db:migrate": "turbo run db:migrate",
    "db:seed": "turbo run db:seed",
    "prepare": "husky"
  },
  "devDependencies": {
    "turbo": "^2.9.14",
    "typescript": "5.4.5",
    "@types/node": "^20.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "prettier": "^3.2.0"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.3.10"
  },
  "packageManager": "bun@1.3.10",
  "overrides": {
    "ajv": "^8.20.0",
    "js-yaml": "^4.1.1",
    "lodash": "^4.18.1",
    "postcss": "^8.5.15",
    "ws": "^8.20.1"
  }
}
